# Copie para .env e ajuste:  cp .env.example .env
# O arquivo .env NÃO vai para o Git (está no .gitignore).

# Endereço público do site:
#  - Com domínio (HTTPS automático via Let's Encrypt):
#      DOMAIN=quiz.seudominio.com.br
#  - Sem domínio, só pelo IP da VPS (apenas HTTP, sem cadeado):
#      DOMAIN=:80
DOMAIN=:80

# Senha da tela de administração de perguntas (/admin). TROQUE em produção!
ADMIN_PASSWORD=troque-esta-senha
